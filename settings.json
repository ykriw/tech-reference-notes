{
  /*
   * 2026-04-26
   * テーマカラーの調整
   */
  "workbench.colorCustomizations": {
    "editor.background": "#f6f7f0", // エディタ部プレビュー部両方反映
    "editor.foreground": "#4d2323", // デフォルトでOK
    "editor.lineHighlightBackground": "#f0f0e3", // カーソル行背景色
    "editor.selectionBackground": "#dee493" // 選択範囲
  },
  "markdown.styles": ["markdown-preview.css"], // CSSファイル指定
  // エディタ部のカラー指定
  "editor.tokenColorCustomizations": {
    "comments": "#22aa16",
    "textMateRules": [
      {
        "scope": ["markup.heading.markdown"], // 見出し
        "settings": {
          "foreground": "#3b4600"
        }
      },
      {
        "scope": "meta.paragraph.markdown", // 段落
        "settings": {
          "foreground": "#575757"
        }
      },
      {
        "scope": "markup.bold", // 強調
        "settings": {
          "foreground": "#614f2e",
          "fontStyle": ""
        }
      },
      {
        "scope": ["string"], // []の中の部分
        "settings": {
          "foreground": "#cf8e00",
          "fontStyle": ""
        }
      },
      {
        "scope": ["entity.name.tag", "punctuation.definition.tag"], // 薄くしたいもの
        "settings": {
          "foreground": "#95ad29",
          "fontStyle": ""
        }
      },
      {
        "scope": [
          "punctuation.definition.quote.begin.markdown", // >マーク
          "punctuation.definition.list.begin.markdown" // -マーク
        ],
        "settings": {
          "foreground": "#a200ff",
          "fontStyle": "bold"
        }
      },
      {
        "scope": [
          "markup.fenced_code.block.markdown", // コードブロック／その他
          "markup.inline.raw",
          "markup.underline" // リンクの()の方
        ],
        "settings": {
          "foreground": "#cf8e00"
        }
      },
      {
        // セパレータ
        "scope": ["meta.separator.markdown"],
        "settings": {
          "foreground": "#adcc00",
          "fontStyle": "bold"
        }
      }
    ]
  }
}
