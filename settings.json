{
  /*
   * 2026-04-26
   * オリジナルテーマの調整
   */
  "workbench.colorCustomizations": {
    // エディタ本体
    "editor.background": "#f2f2ec",
    "editor.foreground": "#575757",
    "editor.lineHighlightBackground": "#e9eadc",
    "editor.selectionBackground": "#dddcc8",

    // 行番号・ガター
    "editorGutter.background": "#f2f2ec",
    "editorLineNumber.foreground": "#aaa58f",
    "editorLineNumber.activeForeground": "#6f6a4f",

    // タブ
    "tab.activeBackground": "#f8f8f1",
    "tab.activeForeground": "#3b4600",
    "tab.inactiveBackground": "#e3e1d2",
    "tab.inactiveForeground": "#77715f",
    "tab.hoverBackground": "#eeecdc",
    "tab.border": "#ccc5aa",
    // "tab.activeBorder": "#b8860b",
    // "tab.activeBorderTop": "#b8860b",

    // タブバー全体
    "editorGroupHeader.tabsBackground": "#d9d5c3",
    "editorGroupHeader.tabsBorder": "#c7bea4"
  },

  "markdown.styles": ["markdown-preview.css"],

  // エディタ部のカラー指定
  "editor.tokenColorCustomizations": {
    "comments": "#6f8f3a",

    "textMateRules": [
      {
        // 段落
        "scope": "meta.paragraph.markdown",
        "settings": {
          "foreground": "#575757"
        }
      },
      {
        // 強調
        "scope": "markup.bold",
        "settings": {
          "foreground": "#3b4600",
          "fontStyle": "bold"
        }
      },
      {
        // [] の中の部分
        "scope": ["string"],
        "settings": {
          "foreground": "#b8860b",
          "fontStyle": ""
        }
      },
      {
        // HTMLタグなど、薄くしたいもの
        "scope": ["entity.name.tag", "punctuation.definition.tag"],
        "settings": {
          "foreground": "#8fa33a",
          "fontStyle": ""
        }
      },
      {
        // 見出し
        "scope": ["markup.heading.markdown"],
        "settings": {
          "foreground": "#3b4600",
          "fontStyle": "bold"
        }
      },
      {
        // リストや引用など
        "scope": [
          "punctuation.definition.quote.begin.markdown",
          "punctuation.definition.list.begin.markdown"
        ],
        "settings": {
          "foreground": "#8a6f24",
          "fontStyle": "bold"
        }
      },
      {
        // コードブロック／インラインコード／リンクURL
        "scope": [
          "markup.fenced_code.block.markdown",
          "markup.inline.raw",
          "markup.underline"
        ],
        "settings": {
          "foreground": "#b8860b"
        }
      },
      {
        // セパレータ ---
        "scope": ["meta.separator.markdown"],
        "settings": {
          "foreground": "#8fa33a",
          "fontStyle": "bold"
        }
      }
    ]
  }
}
